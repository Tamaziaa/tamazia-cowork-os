// tamazia-audit-worker.js · v8 (Phase 6.9)
// Cloudflare Worker · audit.tamazia.co.uk/audit/<slug>-complimentary-audit
//
// Design brief (Aman 2026-05-20):
//   - Compact. Visible at a glance. No P0/P1 jargon, use red/amber/green.
//   - Lawyer-grade language. Cite the actual regulation section, the actual regulator.
//   - Batch breaches by framework. One Tamazia fix line per breach.
//   - Real Tamazia pricing: Foundation £2,500 · Authority £4,500 · Enterprise £9,500.
//   - Real 4-week sprint structure: Technical · Compliance · Off-Page · GBP+Content.
//   - Book URL: https://tamazia.co.uk/book/

const AUDITS = __AUDIT_DATA__;

const BUCKET_LABELS = {
  compliance: 'Regulatory compliance',
  seo: 'On-page SEO',
  technical_seo: 'Technical SEO',
  content_depth: 'Content + E-E-A-T authority',
  security: 'Security headers',
  accessibility: 'Accessibility (WCAG)',
  tls_dns: 'Email + DNS hygiene',
  website: 'Website architecture',
  public_records: 'Public records + trust signals',
  ad_intel: 'Tracking + analytics'
};

// Map raw severity → human label, colour, weight (descending)
const SEV_META = {
  P0: { label: 'Critical', color: '#B91C1C', weight: 3 },
  P1: { label: 'High',     color: '#C8A664', weight: 2 },
  P2: { label: 'Standard', color: '#2E7D32', weight: 1 }
};

// Framework display map: code → { name, regulator, citation_root }
const FRAMEWORK_META = {
