---
// SEOOpportunity.astro · sizing the lift from SEO + technical_seo + content_depth findings.
import type { Pointer } from '../types/AuditPayload';
interface Props { pointers: Pointer[]; }
const { pointers } = Astro.props;
const p0 = (pointers || []).filter(p => p.severity === 'P0').length;
const p1 = (pointers || []).filter(p => p.severity === 'P1').length;
const p2 = (pointers || []).filter(p => p.severity === 'P2').length;

// Conservative uplift heuristic: each P0 unlocks ~8% non-brand organic; P1 ~3%; P2 ~1%.
const upliftPct = Math.min(60, p0 * 8 + p1 * 3 + p2 * 1);
const monthsToCompound = 6;
---
<section id="seo" class="seo-opportunity">
  <div class="container">
    <h2>SEO opportunity sizing</h2>
    <p class="lede">A conservative estimate of organic uplift available once these SEO + technical + content gaps are closed. Compounding window: {monthsToCompound} months.</p>
    <div class="cards">
      <div class="card">
        <p class="metric-label">Estimated non-brand organic uplift</p>
        <p class="metric-big">+{upliftPct}%</p>
        <p class="metric-note">Across {p0 + p1 + p2} addressable findings</p>
      </div>
      <div class="card">
        <p class="metric-label">Compounding to plateau</p>
        <p class="metric-big">{monthsToCompound}–9 months</p>
        <p class="metric-note">Core Web Vitals and content depth carry the long-tail.</p>
      </div>
      <div class="card">
        <p class="metric-label">First-90-days uplift typically realised</p>
        <p class="metric-big">{Math.round(upliftPct * 0.45)}%</p>
        <p class="metric-note">Driven by quick on-page fixes and technical SEO.</p>
      </div>
    </div>
    <p class="caveat">Note: These estimates are heuristic, not promises. Actual uplift depends on backlink profile, competition density and existing topical authority. Tamazia provides a paid forecast model in week 1.</p>
  </div>
</section>
<style>
  .seo-opportunity { padding: 96px 24px; background: var(--tamazia-surface); }
  .container { max-width: 1140px; margin: 0 auto; }
  h2 { font-family: "Editorial New", serif; font-size: clamp(2rem, 4vw, 3rem); margin: 0 0 12px; color: var(--tamazia-burgundy); }
  .lede { font-size: 1.1rem; color: var(--tamazia-body); margin: 0 0 32px; max-width: 64ch; }
  .cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 20px; margin-bottom: 24px; }
  .card { background: white; padding: 24px; border-radius: 8px; border: 1px solid rgba(0,0,0,0.06); }
  .metric-label { font-size: 0.85rem; color: rgba(31, 41, 55, 0.65); letter-spacing: 0.06em; text-transform: uppercase; margin: 0 0 8px; }
  .metric-big { font-size: 2.6rem; font-family: "Editorial New", serif; color: var(--tamazia-burgundy); margin: 0 0 8px; line-height: 1; }
  .metric-note { margin: 0; font-size: 0.9rem; color: rgba(31, 41, 55, 0.7); line-height: 1.5; }
  .caveat { font-size: 0.85rem; color: rgba(31, 41, 55, 0.65); max-width: 64ch; line-height: 1.55; }
</style>
