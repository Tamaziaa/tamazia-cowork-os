---
// /audit/{slug}/{hash} · the canonical audit page route.
// Reads audit_pages by (slug, hash), verifies signature, renders 10 sections.

import AuditCover from '../../../components/AuditCover.astro';
import BucketRadar from '../../../components/BucketRadar.astro';
import TopFindings from '../../../components/TopFindings.astro';
import FindingsList from '../../../components/FindingsList.astro';
import CurrentVsAfter from '../../../components/CurrentVsAfter.astro';
import ComplianceInventory from '../../../components/ComplianceInventory.astro';
import SEOOpportunity from '../../../components/SEOOpportunity.astro';
import InterventionTimeline from '../../../components/InterventionTimeline.astro';
import InvestmentTiers from '../../../components/InvestmentTiers.astro';
import Disclaimer from '../../../components/Disclaimer.astro';
import StickyTOC from '../../../components/StickyTOC.astro';
import type { AuditPayload, Bucket, Pointer } from '../../../types/AuditPayload';

const { slug, hash } = Astro.params;

// Load audit row server-side. The functions/api/audit endpoint already exists from Phase 5.
const apiBase = import.meta.env.PUBLIC_AUDIT_API || 'https://tamazia.co.uk/api/audit';
let page: any = null;
try {
  const r = await fetch(`${apiBase}?slug=${encodeURIComponent(slug || '')}&hash=${encodeURIComponent(hash || '')}`);
  if (r.ok) page = await r.json();
} catch (_e) {}

if (!page) return Astro.redirect('/expired');
if (page.expires_at && new Date(page.expires_at) < new Date()) return Astro.redirect('/expired');

const payload: AuditPayload = page.payload_json || page.payload || page;
const meta = payload.scan_meta;
const pointers: Pointer[] = payload.pointers || [];
const order: Bucket[] = ['compliance','seo','technical_seo','content_depth','security','accessibility','tls_dns','website','public_records','ad_intel'];
const byBucket: Record<Bucket, Pointer[]> = Object.fromEntries(order.map(b => [b, pointers.filter(p => p.bucket === b)])) as any;
const seoBundle = [...byBucket.seo, ...byBucket.technical_seo, ...byBucket.content_depth];

const companyName = page.company || meta?.domain || 'Your firm';
const pageTitle = `${companyName} · Regulatory Signal Scan`;
---
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>{pageTitle}</title>
  <meta name="robots" content="noindex, nofollow" />
  <meta name="description" content={`Live regulatory and SEO audit for ${meta.domain}. ${meta.pointer_count_p0} P0 findings · ${meta.pointer_count_p1} P1 · score ${Math.round(meta.specificity_score * 100)}/100. Generated by Tamazia.`} />
  <meta property="og:title" content={pageTitle} />
  <meta property="og:type" content="article" />
  <meta property="og:image" content={page.share_card_url || 'https://tamazia.co.uk/og/audit-default.png'} />
  <link rel="preconnect" href="https://fonts.gstatic.com" />
  <link rel="stylesheet" href="/styles/global.css" />
  <link rel="stylesheet" href="/styles/audit.css" />
</head>
<body class="audit-page">
  <StickyTOC sections={[
    { id: 'cover', label: 'Cover' },
    { id: 'scores', label: 'Scores' },
    { id: 'top-findings', label: 'Top 3' },
    { id: 'findings', label: 'All findings' },
    { id: 'before-after', label: 'Before / after' },
    { id: 'compliance', label: 'Compliance' },
    { id: 'seo', label: 'SEO opportunity' },
    { id: 'timeline', label: 'Timeline' },
    { id: 'investment', label: 'Investment' },
    { id: 'disclaimer', label: 'About' }
  ]} />
  <AuditCover meta={meta} company={companyName} />
  <BucketRadar buckets={meta.buckets} score={meta.specificity_score} />
  <TopFindings pointers={pointers.filter(p => p.severity === 'P0')} />
  <FindingsList groups={byBucket} />
  <CurrentVsAfter buckets={meta.buckets} />
  <ComplianceInventory pointers={byBucket.compliance} frameworksRouted={meta.frameworks_routed} />
  <SEOOpportunity pointers={seoBundle} />
  <InterventionTimeline pointers={pointers} />
  <InvestmentTiers pointers={pointers} />
  <Disclaimer frameworkVersion={meta.framework_version} />
  <script src="/audit-tracking.js" defer is:inline></script>
</body>
</html>
